while True:
   Number1 = float(input("First number: "))
   Number2 = float(input("Second number: "))
   operation = input("Enter + or - or * or / or type exit:  ")
if operation == "exit":
     print("Goodbye!")
     break
elif operation == "+":
     print( Number1 + Number2)
elif operation == "-":
     print(Number1 - Number2)
elif operation == "*":
    print(Number1 * Number2)
elif operation == "/":
    print(Number1 / Number2)
else:
    print("Error: Invalid operation")

